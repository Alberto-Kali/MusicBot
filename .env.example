# Общие настройки бота
BOT_USERNAME=musikinetbot
STICKER_WELCOME=
STICKER_SUCCESS=

# PostgreSQL
POSTGRES_DB=music_bot
POSTGRES_USER=music
POSTGRES_PASSWORD=music
DATABASE_URL=postgresql+asyncpg://music:music@postgres:5432/music_bot

# URL backend для внутреннего общения контейнеров
BACKEND_INTERNAL_URL=http://backend:8080

# Публичный URL backend для inline stream (должен быть доступен Telegram-клиентам)
BACKEND_PUBLIC_URL=http://localhost:8080

# yt-dlp-ejs настройки backend
YTDLP_JS_RUNTIMES=deno:./include/deno
YTDLP_REMOTE_COMPONENTS=ejs:github

# Секреты:
# - .env.secrets.bot: BOT_TOKEN
# - .env.secrets.backend: BACKEND_COOKIES_B64, BACKEND_BROWSER_JSON_B64
